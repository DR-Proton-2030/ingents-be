						"description": "JWT Auth Token"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"title\": \"Project Kickoff Meeting\",\n    \"description\": \"Initial project discussion and planning\",\n    \"scheduled_start_time\": \"2026-01-20T10:00:00.000Z\",\n    \"scheduled_end_time\": \"2026-01-20T11:00:00.000Z\",\n    \"duration_minutes\": 60,\n    \"timezone\": \"Asia/Kolkata\",\n    \"meeting_type\": \"team\",\n    \"is_recurring\": false,\n    \"reminder_minutes_before\": 15,\n    \"notes\": \"Please come prepared with your project updates\",\n    \"participants\": [\n        {\n            \"user_object_id\": \"64abc123def456...\",\n            \"is_optional\": false\n        },\n        {\n            \"external_email\": \"guest@example.com\",\n            \"external_name\": \"John Guest\",\n            \"is_optional\": true\n        }\n    ]\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{local_base_url}}/api/v1/meetings/create",
					"host": ["{{local_base_url}}"],
					"path": ["api", "v1", "meetings", "create"]
				},
				"description": "Create a new scheduled meeting. Supports one-time and recurring meetings."
			}
